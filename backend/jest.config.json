{
  "testEnvironment": "node",
  "transform": {},
  "testMatch": [
    "**/tests/**/*.test.js"
  ],
  "collectCoverageFrom": [
    "services/**/*.js",
    "utils/**/*.js",
    "controllers/**/*.js",
    "!services/defaultQuizSeeder.js",
    "!utils/logger.js"
  ],
  "coverageReporters": ["text", "lcov", "html"],
  "testTimeout": 15000,
  "verbose": true
}
