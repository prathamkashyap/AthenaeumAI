{
  "name": "@athenaeum/backend",
  "version": "1.0.0",
  "description": "Backend API for AthenaeumAI",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "node --check server.js && node --check worker.js",
    "seed:demo": "node scripts/seedDemo.js",
    "verify:demo": "node scripts/verifyDemo.js",
    "smoke": "node scripts/smokeTest.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest",
    "test:unit": "node --experimental-vm-modules node_modules/.bin/jest --testPathPatterns=tests/unit",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest --testPathPatterns=tests/integration --runInBand --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "test:watch": "node --experimental-vm-modules node_modules/.bin/jest --watch"
  },
  "keywords": ["ai", "learning-platform", "quiz-generation", "spaced-repetition", "rag"],
  "author": "Pratham Kashyap",
  "license": "MIT",
  "dependencies": {
    "bullmq": "^5.80.1",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.1",
    "groq-sdk": "^1.1.2",
    "helmet": "^8.2.0",
    "ioredis": "^5.11.1",
    "mongoose": "^9.6.1",
    "multer": "^2.1.1",
    "pdf-parse-fixed": "^1.1.1",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "yamljs": "^0.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
